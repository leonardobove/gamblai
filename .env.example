ANTHROPIC_API_KEY=your_anthropic_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here       # optional — enables real news research

# Kalshi integration (leave KALSHI_ENABLED=false to use simulation mode)
# Setup:
#   1. Sign up at kalshi.com (demo: demo.kalshi.co)
#   2. Go to Settings → API Keys → Create Key
#   3. Generate RSA key pair:
#        openssl genrsa -out kalshi_private.pem 2048
#        openssl rsa -in kalshi_private.pem -pubout -out kalshi_public.pem
#   4. Upload kalshi_public.pem to Kalshi dashboard
#   5. Copy the Key ID shown after upload into KALSHI_API_KEY_ID below
KALSHI_ENABLED=false
KALSHI_DEMO=true                              # true = demo env, false = live (real money!)
KALSHI_API_KEY_ID=your_key_id_here
KALSHI_PRIVATE_KEY_PATH=kalshi_private.pem
KALSHI_EXECUTE_TRADES=false                   # second safety gate — set true only when ready

MIROFISH_ENABLED=false
MIROFISH_URL=http://localhost:5001

STARTING_BANKROLL=10000.0
EDGE_THRESHOLD=0.04
KELLY_FRACTION=0.25
MAX_POSITION_PCT=0.05
MAX_DRAWDOWN_PCT=0.08
LOG_LEVEL=INFO
